<ci:SettingsPageBase x:Class="ClassIsland.HaiGaoAutoShutdown.Views.SettingsPages.AutoShutdownSettingsPage"
                     xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     mc:Ignorable="d">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16" MaxWidth="960" Margin="0 0 24 0">
      <Border Padding="20"
              CornerRadius="10"
              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
          <StackPanel Spacing="6">
            <TextBlock Text="HL Education + 定时关机" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="每天可添加任意数量的关机计划，并在各自时间显示覆盖所有屏幕的可取消倒计时。"
                       TextWrapping="Wrap"
                       Opacity="0.72" />
          </StackPanel>
          <ToggleSwitch Grid.Column="1"
                        IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                        OnContent="已启用"
                        OffContent="已暂停"
                        VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Padding="20"
              CornerRadius="10"
              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="每日关机计划" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="计划数量不设固定值，每项都可自定义名称、时间和启用状态。"
                         TextWrapping="Wrap" Opacity="0.68" />
            </StackPanel>
            <Button Grid.Column="1" Content="新增关机计划"
                    Click="AddSchedule_OnClick"
                    VerticalAlignment="Center" />
          </Grid>

          <ItemsControl ItemsSource="{Binding Settings.Schedules}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="14" Margin="0 0 0 10" CornerRadius="7"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                  <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                  OnContent="此计划已启用" OffContent="此计划已暂停" />
                    <Button Grid.Column="1" Content="删除" Click="RemoveSchedule_OnClick" />
                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0 12 0 0"
                          ColumnDefinitions="*,Auto" ColumnSpacing="24">
                      <StackPanel Spacing="5">
                        <TextBlock Text="计划名称" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Name, Mode=TwoWay}"
                                 Watermark="例如：午休关机" MinWidth="240" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="每天执行时间" FontWeight="SemiBold" />
                        <TimePicker SelectedTime="{Binding ShutdownTime, Mode=TwoWay}"
                                    Width="170" HorizontalAlignment="Left" />
                      </StackPanel>
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="列表为空或所有计划均暂停时不会自动关机；错过计划时间时不会补触发。"
                     TextWrapping="Wrap" Opacity="0.68" />

          <StackPanel Spacing="6">
            <TextBlock Text="统一倒计时秒数" FontWeight="SemiBold" />
            <NumericUpDown Minimum="1"
                           Maximum="3600"
                           Increment="1"
                           Value="{Binding Settings.CountdownSeconds, Mode=TwoWay}"
                           Width="170"
                           HorizontalAlignment="Left" />
            <TextBlock Text="所有计划共用此倒计时，可设置 1–3600 秒；倒计时期间点击任意屏幕即可取消。"
                       TextWrapping="Wrap" Opacity="0.68" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Padding="20"
              CornerRadius="10"
              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
          <StackPanel Spacing="7">
            <TextBlock Text="运行状态" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Settings.NextOccurrenceText}"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Settings.RuntimeStatus}"
                       TextWrapping="Wrap"
                       Opacity="0.72" />
          </StackPanel>
          <Button x:Name="PreviewButton"
                  Grid.Column="1"
                  Content="安全预览倒计时"
                  Click="Preview_OnClick"
                  VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Padding="16"
              CornerRadius="8"
              Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
        <TextBlock Text="倒计时结束后执行 Windows 正常关机，不会强制关闭含有未保存内容的程序。锁屏时计划仍会执行，但锁屏界面上看不到提示，也无法点击取消。"
                   TextWrapping="Wrap"
                   Opacity="0.76" />
      </Border>
    </StackPanel>
  </ScrollViewer>
</ci:SettingsPageBase>
